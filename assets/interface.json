    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "Anados",
                "screencap": "PrintWindow", // 截图方式
                "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
                "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    // 可选的 agent 示例
    // "agent": {
    //     "child_exec": "python",
    //     "child_args": [
    //         "./agent/main.py"
    //     ]
    // },
     "import": [
//        "tasks/startgame.json",
//        "tasks/endgame.json"
    ],
    "task": [
        {
            "name": "进入游戏",
            "entry": "startgame",
            "option": [
                "是否领取邮件"
            ]
        },
        {
            "name": "刷素材",
            "entry": "obtainmaterials",
            "option": [
                "难度",
                "关卡",
                "次数",
                "是否跳过战斗"
            ]
        },
        {
            "name": "当期活动",
            "entry": "findmap",
            "option": [
                "活动",
                "关卡",
//                "次数",
                "是否跳过战斗"
            ]
        },
        {
            "name": "主线故事",
            "entry": "obtainmaterials",
            "option": [
                "章节",
                "关卡",
                "次数",
                "是否跳过战斗"
            ]
        },
        {
            "name": "退出游戏",
            "entry": "endgame"
        }
    ],
    "option": {
        "是否领取邮件": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "startgame": {  
                            "next": "checkdaily"  // 控制跳转到返回主界面节点  
                     }    
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "startgame": {  
                            "next": "checkdaily_nomail"  // 控制跳转到返回主界面节点  
