{
    "interface_version": 2,
    "name": "MaaADr",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "QQ群: 1071729734",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaADr!",
    // 填写项目地址和版本号可实现自动更新功能
    // "github": "https://github.com/Azureetude/MAAADr",
    // "version": "0.0.0.1",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "Anados",
                "screencap": "PrintWindow", // 截图方式
                "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
                "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    // 可选的 agent 示例
    // "agent": {
    //     "child_exec": "python",
    //     "child_args": [
    //         "./agent/main.py"
    //     ]
    // },
    "group": [
        {
            "name": "daily",
            "label": "日常任务"
        },
        {
            "name": "standalone",
            "label": "独立任务"
        }
    ],
     "import": [
        "./tasks/preset/Daily.json",
        "./tasks/opengame.json",
        "./tasks/homepagess.json",
        "./tasks/getitem.json",
        "./tasks/mainstory.json",
//        "./tasks/Closegame.json"
     ]
}